import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt

# Load cleaned data
df = pd.read_csv('Dataset/Cleaned_Data.csv')

# Set aesthetic style
sns.set(style="whitegrid")

# 1. Salary Distribution (Histogram)
plt.figure(figsize=(10, 6))
sns.histplot(df['salary_in_usd'], kde=True, color='blue')
plt.title('Distribution of Salaries in USD')
plt.xlabel('Salary (USD)')
plt.savefig('HTML_Dashboard/assets/salary_dist.png')
plt.close()

# 2. Salary by Experience Level (Boxplot)
plt.figure(figsize=(10, 6))
sns.boxplot(x='experience_level_full', y='salary_in_usd', data=df, palette='Set2')
plt.title('Salary by Experience Level')
plt.savefig('HTML_Dashboard/assets/salary_by_experience.png')
plt.close()

# 3. Salary Trends over Years (Line Chart)
plt.figure(figsize=(10, 6))
df_trend = df.groupby('work_year')['salary_in_usd'].mean().reset_index()
sns.lineplot(x='work_year', y='salary_in_usd', data=df_trend, marker='o')
plt.title('Average Salary Trend (2020-2022)')
plt.savefig('HTML_Dashboard/assets/salary_trend.png')
plt.close()

# 4. Job Title Analysis (Top 10)
plt.figure(figsize=(10, 8))
top_jobs = df['job_title'].value_counts().head(10)
sns.barplot(y=top_jobs.index, x=top_jobs.values, palette='viridis')
plt.title('Top 10 Data Science Job Titles')
plt.savefig('HTML_Dashboard/assets/top_jobs.png')
plt.close()

# 5. Remote Ratio vs Salary (Bar Chart)
plt.figure(figsize=(10, 6))
sns.barplot(x='remote_status', y='salary_in_usd', data=df, estimator=np.mean)
plt.title('Average Salary by Remote Status')
plt.savefig('HTML_Dashboard/assets/salary_remote.png')
plt.close()

print("Visualizations generated and saved to HTML_Dashboard/assets/")
